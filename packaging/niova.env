# /etc/niova/niova.env
# Environment file for Niova Control Plane services.
# Edit this file on each node before starting the services.
#
# After editing, apply changes with:
#   systemctl daemon-reload
#   systemctl restart niova-pmdbserver niova-proxy niova-monitor

# ---------------------------------------------------------------------------
# Cluster identity — generated by gen_raft_cfgs.sh
# RAFT_UUID is the same on every node in the cluster.
# PEER_UUID is unique to this node (read from the .peer file for this node's IP).
# CLIENT_UUID is unique to the proxy on this node — generate with: uuidgen
# ---------------------------------------------------------------------------
RAFT_UUID=
PEER_UUID=
CLIENT_UUID=

# ---------------------------------------------------------------------------
# Paths
# ---------------------------------------------------------------------------
# Directory where .raft, .peer, and gossipNodes files live.
NIOVA_LOCAL_CTL_SVC_DIR=/var/lib/niova/configs

# Inotify base path used by the niova control interface.
NIOVA_INOTIFY_BASE_PATH=/var/lib/niova/ctl

# Path to the RocksDB store for this node (used by cp-monitor).
# Must match the STORE path in this node's .peer file.
DB_PATH=/var/lib/niova/db

# ---------------------------------------------------------------------------
# Application settings
# ---------------------------------------------------------------------------
NIOVA_APPLY_HANDLER_VERSION=0

# Set to "false" to disable JWT authentication (not recommended for production).
AUTH_ENABLED=true

# Base64-encoded 32-byte encryption key for user token encryption.
# Generate with: openssl rand -base64 32
# WARNING: Change this before starting the service. All nodes in the cluster
# must share the same key.
USER_ENCRYPTION_KEY=
